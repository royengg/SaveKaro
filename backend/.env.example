# Environment
NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/savekaro

# Redis (for BullMQ job queues)
REDIS_URL=redis://localhost:6379
USE_QUEUE=false  # Set to true for production with Redis

# JWT (REQUIRED in production — app will crash without it)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
REFRESH_SECRET=your-refresh-secret-key-change-in-production

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# Reddit API
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=SaveKaro/1.0 by YourUsername

# Email (Resend)
RESEND_API_KEY=your-resend-api-key
FROM_EMAIL=deals@yourdomain.com

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Scraper (only used if USE_QUEUE=false)
ENABLE_SCRAPER=true

# Logging
LOG_LEVEL=info

# Gemini AI (for title cleaning)
GEMINI_API_KEY=your-gemini-api-key


AMAZON_AFFILIATE_TAG=your-amazon-tag-21        # From affiliate-program.amazon.in
FLIPKART_AFFILIATE_ID=your-flipkart-id         # From affiliate.flipkart.com
